// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
}

enum VendorStatus {
  PENDING_VERIFICATION
  APPROVED
  REJECTED
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  DELETED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum FulfillmentStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum NotificationType {
  ORDER_UPDATE
  PRODUCT_APPROVED
  VENDOR_REJECTED
  PROMO
  SYSTEM
}

// ============================================================================
// USERS & AUTHENTICATION
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique @db.VarChar(255)
  passwordHash  String?   @db.Text // NULL for OAuth users
  role          UserRole  @default(CUSTOMER)
  firstName     String?   @db.VarChar(100)
  lastName      String?   @db.VarChar(100)
  avatar        String?   @db.Text
  phone         String?   @db.VarChar(20)
  gender        String?   @db.VarChar(20)
  dateOfBirth   DateTime?
  bio           String?   @db.Text

  isActive         Boolean  @default(true)
  isEmailVerified  Boolean  @default(false)
  lastLoginAt      DateTime?
  lastLoginIP      String?  @db.VarChar(45)

  // Relationships
  vendorProfile    VendorProfile?
  refreshTokens    RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  addresses        Address[]
  orders           Order[]
  cartItems        CartItem[]
  reviews          Review[]
  wishlistItems    WishlistItem[]
  notifications    Notification[]
  auditLogs        AuditLog[]       @relation("UserAuditLogs")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
}

// ============================================================================
// VENDOR MANAGEMENT
// ============================================================================

model VendorProfile {
  id                    String  @id @default(cuid())
  userId                String  @unique
  storeName             String  @unique @db.VarChar(255)
  description           String? @db.Text
  logo                  String? @db.Text
  banner                String? @db.Text

  verificationStatus    VendorStatus @default(PENDING_VERIFICATION)
  rating                Float?  @default(0)
  reviewCount           Int     @default(0)

  bankAccountName       String? @db.VarChar(255)
  bankAccountNumber     String? @db.VarChar(255) // Should be encrypted
  bankCode              String? @db.VarChar(20)
  taxId                 String? @db.VarChar(50)
  businessLicense       String? @db.Text

  rejectionReason       String? @db.Text

  // Relationships
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  products              Product[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  @@index([verificationStatus])
  @@index([storeName])
  @@index([userId])
}

// ============================================================================
// CATEGORIES
// ============================================================================

model Category {
  id            String  @id @default(cuid())
  name          String  @unique @db.VarChar(255)
  slug          String  @unique @db.VarChar(255)
  description   String? @db.Text
  image         String? @db.Text
  parentId      String?
  displayOrder  Int     @default(0)
  isActive      Boolean @default(true)

  // Self-join for hierarchy
  parent        Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      Category[] @relation("CategoryHierarchy")

  products      Product[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([parentId])
}

// ============================================================================
// PRODUCTS & INVENTORY
// ============================================================================

model Product {
  id                    String  @id @default(cuid())
  vendorId              String
  categoryId            String
  name                  String  @db.VarChar(255)
  slug                  String  @unique @db.VarChar(255)
  description           String? @db.Text
  shortDescription      String? @db.VarChar(500)

  basePrice             Float
  discountPercentage    Float   @default(0)
  finalPrice            Float   // Calculated: basePrice * (1 - discountPercentage / 100)

  sku                   String  @unique @db.VarChar(100)
  stock                 Int     @default(0)
  lowStockThreshold     Int     @default(10)

  rating                Float?  @default(0)
  reviewCount           Int     @default(0)

  status                ProductStatus @default(DRAFT)
  approvedBy            String?
  approvalReason        String? @db.Text

  tags                  String[] @default([]) // JSON array of tags
  
  // Relationships
  vendor                VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category              Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images                ProductImage[]
  cartItems             CartItem[]
  reviews               Review[]
  wishlistItems         WishlistItem[]
  orderItems            OrderItem[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  @@index([vendorId])
  @@index([categoryId])
  @@index([slug])
  @@index([status])
  @@index([sku])
}

model ProductImage {
  id          String  @id @default(cuid())
  productId   String
  imageUrl    String  @db.Text
  altText     String? @db.VarChar(255)
  displayOrder Int    @default(0)

  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([productId])
}

// ============================================================================
// SHOPPING CART
// ============================================================================

model Cart {
  id          String  @id @default(cuid())
  userId      String?
  sessionId   String? // For guest carts
  items       CartItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([sessionId])
}

model CartItem {
  id          String  @id @default(cuid())
  cartId      String
  productId   String
  quantity    Int
  addedPrice  Float   // Price snapshot when added

  cart        Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

// ============================================================================
// WISHLIST
// ============================================================================

model WishlistItem {
  id          String  @id @default(cuid())
  userId      String
  productId   String

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ============================================================================
// ORDERS & FULFILLMENT
// ============================================================================

model Order {
  id                    String  @id @default(cuid())
  userId                String
  orderNumber           String  @unique @db.VarChar(50)

  status                OrderStatus @default(PENDING)
  paymentStatus         PaymentStatus @default(PENDING)
  paymentMethodId       String?
  paymentGateway        String? @db.VarChar(50)

  totalAmount           Float
  taxAmount             Float   @default(0)
  shippingCost          Float   @default(0)
  discountAmount        Float   @default(0)
  finalAmount           Float

  couponCode            String? @db.VarChar(50)

  shippingAddressId     String?
  billingAddressId      String?
  shippingCarrier       String? @db.VarChar(100)
  trackingNumber        String? @db.VarChar(100)

  notes                 String? @db.Text
  cancelReason          String? @db.Text

  // Relationships
  user                  User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  items                 OrderItem[]
  shippingAddress       Address? @relation("ShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  billingAddress        Address? @relation("BillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id                    String  @id @default(cuid())
  orderId               String
  productId             String
  vendorId              String

  quantity              Int
  unitPrice             Float
  discount              Float   @default(0)
  total                 Float

  fulfillmentStatus     FulfillmentStatus @default(PENDING)
  shippedAt             DateTime?
  deliveredAt           DateTime?

  // Relationships
  order                 Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product               Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([vendorId])
  @@index([fulfillmentStatus])
}

// ============================================================================
// ADDRESSES
// ============================================================================

model Address {
  id          String  @id @default(cuid())
  userId      String
  label       String? @db.VarChar(50) // HOME, WORK, OTHER
  fullName    String  @db.VarChar(255)
  phone       String  @db.VarChar(20)

  addressLine1  String  @db.VarChar(255)
  addressLine2  String? @db.VarChar(255)
  city          String  @db.VarChar(100)
  state         String  @db.VarChar(100)
  zipCode       String  @db.VarChar(20)
  country       String  @db.VarChar(100)

  isDefault   Boolean @default(false)

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingOrders  Order[] @relation("ShippingAddress")
  billingOrders   Order[] @relation("BillingAddress")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ============================================================================
// REVIEWS & RATINGS
// ============================================================================

model Review {
  id          String  @id @default(cuid())
  productId   String
  userId      String

  rating      Int     // 1-5
  title       String? @db.VarChar(255)
  comment     String? @db.Text

  isVerified  Boolean @default(false) // Purchased from this product
  isApproved  Boolean @default(false) // Admin approved

  // Relationships
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@unique([productId, userId]) // One review per user per product
  @@index([productId])
  @@index([userId])
  @@index([isApproved])
}

// ============================================================================
// PROMOTIONS & DISCOUNTS
// ============================================================================

model Coupon {
  id                String  @id @default(cuid())
  code              String  @unique @db.VarChar(50)

  type              String  @db.VarChar(20) // PERCENTAGE, FIXED_AMOUNT
  value             Float
  minOrderValue     Float   @default(0)
  maxDiscount       Float?

  usageLimit        Int?
  timesUsed         Int     @default(0)

  validFrom         DateTime
  validTo           DateTime
  isActive          Boolean @default(true)

  applicableCategories String[] @default([]) // JSON array of category IDs
  applicableVendors    String[] @default([]) // JSON array of vendor IDs

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  @@index([code])
  @@index([isActive])
}

// ============================================================================
// CONTENT MANAGEMENT
// ============================================================================

model Banner {
  id          String  @id @default(cuid())
  title       String  @db.VarChar(255)
  content     String? @db.Text
  imageUrl    String  @db.Text
  link        String? @db.VarChar(500)
  displayOrder Int    @default(0)

  isActive    Boolean @default(true)
  validFrom   DateTime
  validTo     DateTime

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([displayOrder])
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id            String  @id @default(cuid())
  userId        String
  title         String  @db.VarChar(255)
  message       String  @db.Text
  type          NotificationType

  relatedEntity String? @db.VarChar(50) // Product, Order, etc.
  relatedId     String? @db.VarChar(50)

  readAt        DateTime?

  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([readAt])
  @@index([type])
}

// ============================================================================
// AUDIT LOGGING
// ============================================================================

model AuditLog {
  id          String  @id @default(cuid())
  userId      String?
  action      String  @db.VarChar(100) // CREATE_PRODUCT, APPROVE_VENDOR, etc.
  entity      String  @db.VarChar(50)  // Product, Vendor, User, Order, etc.
  entityId    String  @db.VarChar(50)
  changes     String  @db.Text // JSON: { before: {}, after: {} }

  ipAddress   String? @db.VarChar(45)
  userAgent   String? @db.Text

  user        User?   @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================================
// AUTH TOKENS
// ============================================================================

model RefreshToken {
  id            String   @id @default(cuid())
  userId        String
  jti           String   @unique @db.VarChar(100)
  tokenHash     String   @db.Text
  expiresAt     DateTime
  revokedAt     DateTime?
  replacedByJti String?   @db.VarChar(100)
  ipAddress     String?   @db.VarChar(45)
  userAgent     String?   @db.Text

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([jti])
  @@index([expiresAt])
  @@index([revokedAt])
}

model PasswordResetToken {
  id            String   @id @default(cuid())
  userId        String
  tokenHash     String   @db.Text
  expiresAt     DateTime
  usedAt        DateTime?

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}
