{
  "name": "@edumart/ui",
  "version": "0.1.0",
  "description": "Shared UI components and design tokens for EduMart",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens": {
